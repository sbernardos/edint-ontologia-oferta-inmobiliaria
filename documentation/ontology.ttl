#################################################################

###  http://vocab.linkeddata.es/datosabiertos/def/oferta-inmobiliaria/propertyType
<http://vocab.linkeddata.es/datosabiertos/def/oferta-inmobiliaria/propertyType> rdf:type owl:ObjectProperty ;
                                                                                rdfs:domain <http://vocab.linkeddata.es/datosabiertos/def/oferta-inmobiliaria/RealEstateListing> ;
                                                                                rdfs:range <http://www.w3.org/2004/02/skos/core#Concept> ;
                                                                                rdfs:comment "Property indicating the type of real estate property in the listing (e.g., local, office, warehouse, dwelling, plot). Reuses the Spanish Cadastre use vocabulary."@en ,
                                                                                             "Propiedad que indica el tipo de inmueble en el anuncio (ej. local, oficina, nave, vivienda, solar). Reutiliza el vocabulario de usos del Catastro Español."@es ;
                                                                                rdfs:label "property type"@en ,
                                                                                           "tipo de inmueble"@es .


###  http://vocab.linkeddata.es/datosabiertos/def/oferta-inmobiliaria/refersToCadastralEntity
<http://vocab.linkeddata.es/datosabiertos/def/oferta-inmobiliaria/refersToCadastralEntity> rdf:type owl:ObjectProperty ;
                                                                                           rdfs:domain <http://vocab.linkeddata.es/datosabiertos/def/oferta-inmobiliaria/RealEstateListing> ;
                                                                                           rdfs:range [ rdf:type owl:Class ;
                                                                                                        owl:unionOf ( <http://vocab.linkeddata.es/datosabiertos/def/catastro/CadastralParcel>
                                                                                                                      <http://vocab.linkeddata.es/datosabiertos/def/catastro/CadastralProperty>
                                                                                                                    )
                                                                                                      ] ;
                                                                                           rdfs:comment "Relación que vincula un anuncio inmobiliario con su entidad catastral correspondiente (parcela o inmueble). Esto permite acceder a información catastral como el uso, la clase, la dirección y la referencia a través de la ontología del Catastro. Para ventas de solo terreno, se enlaza a una CadastralParcel. Para edificios o unidades, se enlaza a una CadastralProperty."@es ,
                                                                                                        "Relationship linking a real estate listing to its corresponding cadastral entity (parcel or property). This allows access to cadastral information such as use, class, address, and reference through the Cadastre ontology. For land-only sales, it links to a CadastralParcel. For buildings or units, it links to a CadastralProperty."@en ;
                                                                                           rdfs:label "refers to cadastral entity"@en ,
                                                                                                      "se refiere a entidad catastral"@es .


###  http://vocab.linkeddata.es/datosabiertos/def/oferta-inmobiliaria/transactionType
<http://vocab.linkeddata.es/datosabiertos/def/oferta-inmobiliaria/transactionType> rdf:type owl:ObjectProperty ;
                                                                                   rdfs:domain <http://vocab.linkeddata.es/datosabiertos/def/oferta-inmobiliaria/RealEstateListing> ;
                                                                                   rdfs:range <http://www.w3.org/2004/02/skos/core#Concept> ;
                                                                                   rdfs:comment "Property indicating type of real estate transaction (sale, rent, or transfer). Uses the transaction type controlled vocabulary."@en ,
                                                                                                "Propiedad que indica el tipo de transacción inmobiliaria (venta, alquiler o traspaso). Utiliza el vocabulario controlado de tipos de transacción."@es ;
                                                                                   rdfs:label "tipo de transacción"@es ,
                                                                                              "transaction type"@en .


