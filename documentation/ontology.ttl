#################################################################
#    Object Properties
#################################################################

###  https://edint.github.io/edint-ontologia-catastro/ontology/catastro#hasListing
<https://edint.github.io/edint-ontologia-catastro/ontology/catastro#hasListing> rdf:type owl:ObjectProperty .


###  https://edint.github.io/edint-ontologia-inmuebles/ontology/inmobiliaria#propertyType
:propertyType rdf:type owl:ObjectProperty ;
              rdfs:domain :RealEstateListing ;
              rdfs:range <http://www.w3.org/2004/02/skos/core#Concept> ;
              rdfs:comment "Property indicating the type of real estate property in the listing (e.g., local, office, warehouse, dwelling, plot). Reuses the Spanish Cadastre use vocabulary."@en ,
                           "Propiedad que indica el tipo de inmueble en el anuncio (ej. local, oficina, nave, vivienda, solar). Reutiliza el vocabulario de usos del Catastro Español."@es ;
              rdfs:label "property type"@en ,
                         "tipo de inmueble"@es .


###  https://edint.github.io/edint-ontologia-inmuebles/ontology/inmobiliaria#refersToCadastralEntity
:refersToCadastralEntity rdf:type owl:ObjectProperty ;
                         owl:inverseOf <https://edint.github.io/edint-ontologia-catastro/ontology/catastro#hasListing> ;
                         rdfs:domain :RealEstateListing ;
                         rdfs:range [ rdf:type owl:Class ;
                                      owl:unionOf ( <https://edint.github.io/edint-ontologia-catastro/ontology/catastro#CadastralParcel>
                                                    <https://edint.github.io/edint-ontologia-catastro/ontology/catastro#CadastralProperty>
                                                  )
                                    ] ;
                         rdfs:comment "Relación que vincula un anuncio inmobiliario con su entidad catastral correspondiente (parcela o inmueble). Esto permite acceder a información catastral como el uso, la clase, la dirección y la referencia a través de la ontología del Catastro. Para ventas de solo terreno, se enlaza a una CadastralParcel. Para edificios o unidades, se enlaza a una CadastralProperty."@es ,
                                      "Relationship linking a real estate listing to its corresponding cadastral entity (parcel or property). This allows access to cadastral information such as use, class, address, and reference through the Cadastre ontology. For land-only sales, it links to a CadastralParcel. For buildings or units, it links to a CadastralProperty."@en ;
                         rdfs:label "refers to cadastral entity"@en ,
                                    "se refiere a entidad catastral"@es .


###  https://edint.github.io/edint-ontologia-inmuebles/ontology/inmobiliaria#transactionType
:transactionType rdf:type owl:ObjectProperty ;
                 rdfs:domain :RealEstateListing ;
                 rdfs:range <http://www.w3.org/2004/02/skos/core#Concept> ;
                 rdfs:comment "Property indicating type of real estate transaction (sale, rent, or transfer). Uses the transaction type controlled vocabulary."@en ,
                              "Propiedad que indica el tipo de transacción inmobiliaria (venta, alquiler o traspaso). Utiliza el vocabulario controlado de tipos de transacción."@es ;
                 rdfs:label "tipo de transacción"@es ,
                            "transaction type"@en .


#################################################################
#    Data properties
#################################################################

###  http://purl.org/dc/terms/identifier
<http://purl.org/dc/terms/identifier> rdf:type owl:DatatypeProperty ;
                                      rdfs:domain :RealEstateListing ;
                                      rdfs:range xsd:string ;
                                      rdfs:comment "Identificador único para el anuncio inmobiliario."@es ,
                                                   "Unique identifier for the real estate listing."@en ;
                                      rdfs:label "identificador"@es ,
                                                 "identifier"@en .


###  https://edint.github.io/edint-ontologia-inmuebles/ontology/inmobiliaria#isActive
:isActive rdf:type owl:DatatypeProperty ;
          rdfs:domain :RealEstateListing ;
          rdfs:range xsd:boolean ;
          rdfs:comment "Property indicating whether the real estate listing is currently active (true) or inactive (false)."@en ,
                       "Propiedad que indica si el anuncio inmobiliario está actualmente activo (verdadero) o inactivo (falso)."@es ;
          rdfs:label "está activo"@es ,
                     "is active"@en .


#################################################################
#    Classes
#################################################################

###  http://www.w3.org/2004/02/skos/core#Concept
<http://www.w3.org/2004/02/skos/core#Concept> rdf:type owl:Class .


###  https://edint.github.io/edint-ontologia-catastro/ontology/catastro#CadastralParcel
<https://edint.github.io/edint-ontologia-catastro/ontology/catastro#CadastralParcel> rdf:type owl:Class .


###  https://edint.github.io/edint-ontologia-catastro/ontology/catastro#CadastralProperty
<https://edint.github.io/edint-ontologia-catastro/ontology/catastro#CadastralProperty> rdf:type owl:Class .


###  https://edint.github.io/edint-ontologia-inmuebles/ontology/inmobiliaria#RealEstateListing
:RealEstateListing rdf:type owl:Class ;
                   rdfs:subClassOf [ rdf:type owl:Restriction ;
                                     owl:onProperty <http://purl.org/dc/terms/identifier> ;
                                     owl:cardinality "1"^^xsd:nonNegativeInteger
                                   ] ;
                   rdfs:comment "A real estate listing representing an offer for a property (sale, rent, or transfer). Each listing has a unique identifier and describes the property type, transaction type, and current status."@en ,
                                "Un anuncio inmobiliario que representa una oferta de un inmueble (venta, alquiler o traspaso). Cada anuncio tiene un identificador único y describe el tipo de inmueble, tipo de transacción y estado actual."@es ;
                   rdfs:label "Anuncio Inmobiliario"@es ,
                              "Real Estate Listing"@en .


