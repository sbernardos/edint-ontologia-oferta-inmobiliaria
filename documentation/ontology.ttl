<https://edint.github.io/edint-ontologia-inmuebles/ontology/inmobiliaria> rdf:type owl:Ontology ;
                                                                           owl:versionIRI <https://edint.github.io/edint-ontologia-inmuebles/ontology/inmobiliaria/0.1.0> ;
                                                                           owl:imports <http://vocab.linkeddata.es/datosabiertos/kos/edint/transaction-type> ,
                                                                                       <http://vocab.linkeddata.es/datosabiertos/kos/edint/uso> ,
                                                                                       <http://www.opengis.net/ont/geosparql> ,
                                                                                       <https://edint.github.io/edint-ontologia-catastro/ontology/catastro> ;
