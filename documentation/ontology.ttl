                                                                                                              "Edna Ruckhaus" ,
                                                                                                              "Lucía Sánchez" ,
                                                                                                              "Maria del Socorro Bernardos" ,
                                                                                                              "Oscar Corcho" ;
                                                                           <http://purl.org/dc/terms/description> "Ontology for modeling real estate listings in the Spanish context, including property offers (sale, rent, transfer). Reuses GeoSPARQL and integrates with the Spanish Cadastre ontology."@en ,
                                                                                                                  "Ontología para modelar ofertas inmobiliarias en el contexto español, incluyendo ofertas de inmuebles (venta, alquiler, traspaso). Reutiliza GeoSPARQL y se integra con la ontología del Catastro Español."@es ;
                                                                           <http://purl.org/dc/terms/license> <https://creativecommons.org/licenses/by/4.0/> ;
                                                                           <http://purl.org/dc/terms/modified> "2026-04-14"^^xsd:date ;
                                                                           <http://purl.org/dc/terms/title> "Ontología de Oferta Inmobiliaria Española"@es ,
                                                                                                            "Spanish Real Estate Listing Ontology"@en ;
                                                                           <http://purl.org/vocab/vann/preferredNamespacePrefix> "edintinm" ;
                                                                           <http://purl.org/vocab/vann/preferredNamespaceUri> "https://edint.github.io/edint-ontologia-inmuebles/ontology/inmobiliaria#" ;
                                                                           rdfs:comment "Initial draft version focusing on the RealEstateListing class with its properties for property type, transaction type, and active status."@en ,
                                                                                        "Versión inicial centrada en la clase RealEstateListing con sus propiedades de tipo de inmueble, tipo de transacción y estado activo."@es ;
                                                                           owl:versionInfo "0.1.0" .

