#    Data properties
#################################################################

###  http://purl.org/dc/terms/identifier
<http://purl.org/dc/terms/identifier> rdf:type owl:DatatypeProperty ;
                                      rdfs:domain <http://vocab.linkeddata.es/datosabiertos/def/oferta-inmobiliaria/RealEstateListing> ;
                                      rdfs:range xsd:string ;
                                      rdfs:comment "Identificador único para el anuncio inmobiliario."@es ,
                                                   "Unique identifier for the real estate listing."@en ;
                                      rdfs:label "identificador"@es ,
                                                 "identifier"@en .


###  http://vocab.linkeddata.es/datosabiertos/def/oferta-inmobiliaria/isActive
<http://vocab.linkeddata.es/datosabiertos/def/oferta-inmobiliaria/isActive> rdf:type owl:DatatypeProperty ;
                                                                            rdfs:domain <http://vocab.linkeddata.es/datosabiertos/def/oferta-inmobiliaria/RealEstateListing> ;
                                                                            rdfs:range xsd:boolean ;
                                                                            rdfs:comment "Property indicating whether the real estate listing is currently active (true) or inactive (false)."@en ,
                                                                                         "Propiedad que indica si el anuncio inmobiliario está actualmente activo (verdadero) o inactivo (falso)."@es ;
                                                                            rdfs:label "está activo"@es ,
                                                                                       "is active"@en .


