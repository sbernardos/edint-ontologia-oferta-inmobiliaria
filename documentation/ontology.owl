     -->


    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/catastro/CadastralParcel -->


    <owl:Class rdf:about="http://vocab.linkeddata.es/datosabiertos/def/catastro/CadastralParcel"/>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/catastro/CadastralProperty -->


    <owl:Class rdf:about="http://vocab.linkeddata.es/datosabiertos/def/catastro/CadastralProperty"/>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/oferta-inmobiliaria/RealEstateListing -->


    <owl:Class rdf:about="http://vocab.linkeddata.es/datosabiertos/def/oferta-inmobiliaria/RealEstateListing">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.org/dc/terms/identifier"/>
                <owl:cardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:cardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">A real estate listing representing an offer for a property (sale, rent, or transfer). Each listing has a unique identifier and describes the property type, transaction type, and current status.</rdfs:comment>
        <rdfs:comment xml:lang="es">Un anuncio inmobiliario que representa una oferta de un inmueble (venta, alquiler o traspaso). Cada anuncio tiene un identificador único y describe el tipo de inmueble, tipo de transacción y estado actual.</rdfs:comment>
        <rdfs:label xml:lang="es">Anuncio Inmobiliario</rdfs:label>
        <rdfs:label xml:lang="en">Real Estate Listing</rdfs:label>
    </owl:Class>
    


    <!-- http://www.w3.org/2004/02/skos/core#Concept -->


    <owl:Class rdf:about="http://www.w3.org/2004/02/skos/core#Concept"/>
