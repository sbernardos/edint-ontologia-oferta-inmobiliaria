     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:vann="http://purl.org/vocab/vann/"
     xmlns:terms="http://purl.org/dc/terms/">
    <owl:Ontology rdf:about="http://vocab.linkeddata.es/datosabiertos/def/oferta-inmobiliaria/">
        <owl:versionIRI rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/oferta-inmobiliaria/0.1.0"/>
        <owl:imports rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/catastro/"/>
        <owl:imports rdf:resource="http://www.opengis.net/ont/geosparql"/>
        <ns:license rdf:resource="https://creativecommons.org/licenses/by/4.0/"/>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-04-14</terms:created>
        <terms:creator xml:lang="es">Daniel Doña</terms:creator>
        <terms:creator>Edna Ruckhaus</terms:creator>
        <terms:creator>Lucía Sánchez</terms:creator>
        <terms:creator>Maria del Socorro Bernardos</terms:creator>
        <terms:creator>Oscar Corcho</terms:creator>
        <terms:description xml:lang="en">Ontology for modeling real estate listings in the Spanish context, including property offers (sale, rent, transfer). Reuses GeoSPARQL and integrates with the Spanish Cadastre ontology.</terms:description>
        <terms:description xml:lang="es">Ontología para modelar ofertas inmobiliarias en el contexto español, incluyendo ofertas de inmuebles (venta, alquiler, traspaso). Reutiliza GeoSPARQL y se integra con la ontología del Catastro Español.</terms:description>
        <terms:license rdf:resource="https://creativecommons.org/licenses/by/4.0/"/>
        <terms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-04-14</terms:modified>
        <terms:title xml:lang="es">Ontología de Oferta Inmobiliaria Española</terms:title>
        <terms:title xml:lang="en">Spanish Real Estate Listing Ontology</terms:title>
        <vann:preferredNamespacePrefix>edintinm</vann:preferredNamespacePrefix>
        <vann:preferredNamespaceUri>http://vocab.linkeddata.es/datosabiertos/def/oferta-inmobiliaria/</vann:preferredNamespaceUri>
        <rdfs:comment xml:lang="en">Initial draft version focusing on the RealEstateListing class with its properties for property type, transaction type, and active status.</rdfs:comment>
        <rdfs:comment xml:lang="es">Versión inicial centrada en la clase RealEstateListing con sus propiedades de tipo de inmueble, tipo de transacción y estado activo.</rdfs:comment>
        <owl:versionInfo>0.1.0</owl:versionInfo>
    </owl:Ontology>
    


