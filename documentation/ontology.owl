    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/oferta-inmobiliaria/propertyType -->


    <owl:ObjectProperty rdf:about="http://vocab.linkeddata.es/datosabiertos/def/oferta-inmobiliaria/propertyType">
        <rdfs:domain rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/oferta-inmobiliaria/RealEstateListing"/>
        <rdfs:range rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdfs:comment xml:lang="en">Property indicating the type of real estate property in the listing (e.g., local, office, warehouse, dwelling, plot). Reuses the Spanish Cadastre use vocabulary.</rdfs:comment>
        <rdfs:comment xml:lang="es">Propiedad que indica el tipo de inmueble en el anuncio (ej. local, oficina, nave, vivienda, solar). Reutiliza el vocabulario de usos del Catastro Español.</rdfs:comment>
        <rdfs:label xml:lang="en">property type</rdfs:label>
        <rdfs:label xml:lang="es">tipo de inmueble</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/oferta-inmobiliaria/refersToCadastralEntity -->


    <owl:ObjectProperty rdf:about="http://vocab.linkeddata.es/datosabiertos/def/oferta-inmobiliaria/refersToCadastralEntity">
        <rdfs:domain rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/oferta-inmobiliaria/RealEstateListing"/>
        <rdfs:range>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://vocab.linkeddata.es/datosabiertos/def/catastro/CadastralParcel"/>
                    <rdf:Description rdf:about="http://vocab.linkeddata.es/datosabiertos/def/catastro/CadastralProperty"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:range>
        <rdfs:comment xml:lang="es">Relación que vincula un anuncio inmobiliario con su entidad catastral correspondiente (parcela o inmueble). Esto permite acceder a información catastral como el uso, la clase, la dirección y la referencia a través de la ontología del Catastro. Para ventas de solo terreno, se enlaza a una CadastralParcel. Para edificios o unidades, se enlaza a una CadastralProperty.</rdfs:comment>
        <rdfs:comment xml:lang="en">Relationship linking a real estate listing to its corresponding cadastral entity (parcel or property). This allows access to cadastral information such as use, class, address, and reference through the Cadastre ontology. For land-only sales, it links to a CadastralParcel. For buildings or units, it links to a CadastralProperty.</rdfs:comment>
        <rdfs:label xml:lang="en">refers to cadastral entity</rdfs:label>
        <rdfs:label xml:lang="es">se refiere a entidad catastral</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/oferta-inmobiliaria/transactionType -->


    <owl:ObjectProperty rdf:about="http://vocab.linkeddata.es/datosabiertos/def/oferta-inmobiliaria/transactionType">
        <rdfs:domain rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/oferta-inmobiliaria/RealEstateListing"/>
        <rdfs:range rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <rdfs:comment xml:lang="en">Property indicating type of real estate transaction (sale, rent, or transfer). Uses the transaction type controlled vocabulary.</rdfs:comment>
        <rdfs:comment xml:lang="es">Propiedad que indica el tipo de transacción inmobiliaria (venta, alquiler o traspaso). Utiliza el vocabulario controlado de tipos de transacción.</rdfs:comment>
        <rdfs:label xml:lang="es">tipo de transacción</rdfs:label>
        <rdfs:label xml:lang="en">transaction type</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Data properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://purl.org/dc/terms/identifier -->


    <owl:DatatypeProperty rdf:about="http://purl.org/dc/terms/identifier">
        <rdfs:domain rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/oferta-inmobiliaria/RealEstateListing"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="es">Identificador único para el anuncio inmobiliario.</rdfs:comment>
        <rdfs:comment xml:lang="en">Unique identifier for the real estate listing.</rdfs:comment>
        <rdfs:label xml:lang="es">identificador</rdfs:label>
        <rdfs:label xml:lang="en">identifier</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://vocab.linkeddata.es/datosabiertos/def/oferta-inmobiliaria/isActive -->


    <owl:DatatypeProperty rdf:about="http://vocab.linkeddata.es/datosabiertos/def/oferta-inmobiliaria/isActive">
        <rdfs:domain rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/oferta-inmobiliaria/RealEstateListing"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment xml:lang="en">Property indicating whether the real estate listing is currently active (true) or inactive (false).</rdfs:comment>
        <rdfs:comment xml:lang="es">Propiedad que indica si el anuncio inmobiliario está actualmente activo (verdadero) o inactivo (falso).</rdfs:comment>
        <rdfs:label xml:lang="es">está activo</rdfs:label>
        <rdfs:label xml:lang="en">is active</rdfs:label>
    </owl:DatatypeProperty>
    


