  "http://purl.org/dc/terms/description" : [ {
    "@language" : "en",
    "@value" : "Ontology for modeling real estate listings in the Spanish context, including property offers (sale, rent, transfer). Integrates with the Spanish Cadastre ontology."
  }, {
    "@language" : "es",
    "@value" : "Ontología para modelar ofertas inmobiliarias en el contexto español, incluyendo ofertas de inmuebles (venta, alquiler, traspaso). Se integra con la ontología del Catastro Español."
  } ],
