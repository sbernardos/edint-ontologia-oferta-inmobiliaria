  } ]
}, {
  "@id" : "http://vocab.linkeddata.es/datosabiertos/def/oferta-inmobiliaria/RealEstateListing",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A real estate listing representing an offer for a property (sale, rent, or transfer). Each listing has a unique identifier and describes the property type, transaction type, and current status."
  }, {
    "@language" : "es",
    "@value" : "Un anuncio inmobiliario que representa una oferta de un inmueble (venta, alquiler o traspaso). Cada anuncio tiene un identificador único y describe el tipo de inmueble, tipo de transacción y estado actual."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@id" : "http://vocab.linkeddata.es/datosabiertos/def/oferta-inmobiliaria/"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "es",
    "@value" : "Anuncio Inmobiliario"
  }, {
    "@language" : "en",
    "@value" : "Real Estate Listing"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://org.semanticweb.owlapi/error#Error1"
  } ]
}, {
  "@id" : "http://vocab.linkeddata.es/datosabiertos/def/oferta-inmobiliaria/_:genid-nodeid-node1jmddjsqex2",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ]
}, {
  "@id" : "http://vocab.linkeddata.es/datosabiertos/def/oferta-inmobiliaria/_:genid-nodeid-node1jmddjsqex3",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ]
}, {
  "@id" : "http://vocab.linkeddata.es/datosabiertos/def/oferta-inmobiliaria/isActive",
  "@type" : [ "http://www.w3.org/2002/07/owl#DatatypeProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Property indicating whether the real estate listing is currently active (true) or inactive (false)."
  }, {
    "@language" : "es",
    "@value" : "Propiedad que indica si el anuncio inmobiliario está actualmente activo (verdadero) o inactivo (falso)."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "http://vocab.linkeddata.es/datosabiertos/def/oferta-inmobiliaria/RealEstateListing"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@id" : "http://vocab.linkeddata.es/datosabiertos/def/oferta-inmobiliaria/"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "es",
    "@value" : "está activo"
  }, {
    "@language" : "en",
    "@value" : "is active"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "http://www.w3.org/2001/XMLSchema#boolean"
  } ]
}, {
  "@id" : "http://vocab.linkeddata.es/datosabiertos/def/oferta-inmobiliaria/propertyType",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Property indicating the type of real estate property in the listing (e.g., local, office, warehouse, dwelling, plot). Reuses the Spanish Cadastre use vocabulary."
  }, {
    "@language" : "es",
    "@value" : "Propiedad que indica el tipo de inmueble en el anuncio (ej. local, oficina, nave, vivienda, solar). Reutiliza el vocabulario de usos del Catastro Español."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "http://vocab.linkeddata.es/datosabiertos/def/oferta-inmobiliaria/RealEstateListing"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@id" : "http://vocab.linkeddata.es/datosabiertos/def/oferta-inmobiliaria/"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Property Type"
  }, {
    "@language" : "es",
    "@value" : "Tipo de Inmueble"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "http://www.w3.org/2004/02/skos/core#Concept"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subPropertyOf" : [ {
    "@id" : "_:genid1"
  } ]
}, {
  "@id" : "http://vocab.linkeddata.es/datosabiertos/def/oferta-inmobiliaria/refersToCadastralEntity",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "es",
    "@value" : "Relación que vincula un anuncio inmobiliario con su entidad catastral correspondiente (parcela o inmueble). Esto permite acceder a información catastral como el uso, la clase, la dirección y la referencia a través de la ontología del Catastro. Para ventas de solo terreno, se enlaza a una CadastralParcel. Para edificios o unidades, se enlaza a una CadastralProperty."
  }, {
    "@language" : "en",
    "@value" : "Relationship linking a real estate listing to its corresponding cadastral entity (parcel or property). This allows access to cadastral information such as use, class, address, and reference through the Cadastre ontology. For land-only sales, it links to a CadastralParcel. For buildings or units, it links to a CadastralProperty."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "http://vocab.linkeddata.es/datosabiertos/def/oferta-inmobiliaria/RealEstateListing"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@id" : "http://vocab.linkeddata.es/datosabiertos/def/oferta-inmobiliaria/"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "refers to cadastral entity"
  }, {
    "@language" : "es",
    "@value" : "se refiere a entidad catastral"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "_:genid2"
  } ]
}, {
  "@id" : "http://vocab.linkeddata.es/datosabiertos/def/oferta-inmobiliaria/transactionType",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Property indicating type of real estate transaction (sale, rent, or transfer). Uses the transaction type controlled vocabulary."
  }, {
    "@language" : "es",
    "@value" : "Propiedad que indica el tipo de transacción inmobiliaria (venta, alquiler o traspaso). Utiliza el vocabulario controlado de tipos de transacción."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "http://vocab.linkeddata.es/datosabiertos/def/oferta-inmobiliaria/RealEstateListing"
  } ],
