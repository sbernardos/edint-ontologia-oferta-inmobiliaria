@prefix rdfs: <http://www.w3.org/2000/01/rdf-syntax-ns#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix cc: <http://creativecommons.org/ns#> .
@prefix edintkos: <http://vocab.linkeddata.es/datosabiertos/kos/edint/> .

@prefix edintkos-clase: <http://vocab.linkeddata.es/datosabiertos/kos/edint/clase/> .

# =============================================================================
# ONTOLOGY METADATA
# =============================================================================

<http://vocab.linkeddata.es/datosabiertos/kos/edint/clase> a owl:Ontology ;
    owl:versionIRI <http://vocab.linkeddata.es/datosabiertos/kos/edint/clase/0.1.2> ;
    owl:versionInfo "0.1.2" ;
    dct:title "Controlled Vocabulary of Property Classification for Spanish Cadastre"@en ;
    dct:title "Vocabulario Controlado de Clasificación de Inmuebles para el Catastro Español"@es ;
    dct:description "SKOS concept scheme defining the legally mandated property classifications (Urban, Rural, BICES) and their subcategories in the Spanish Cadastre system according to RDLeg 1/2004."@en ;
    dct:description "Esquema de conceptos SKOS que define las clasificaciones de inmuebles obligatorias por ley (Urbano, Rústico, BICES) y sus subcategorías en el sistema del Catastro Español según el RDLeg 1/2004."@es ;
    dct:issued "2026-04-13"^^xsd:date ;
    dct:modified "2026-04-13"^^xsd:date ;
    dct:creator "Daniel Doña"@es ,
                "Edna Ruckhaus" ,
                "Lucía Sánchez" ,
                "Maria del Socorro Bernardos" ,
                "Oscar Corcho" ;
    cc:license <https://creativecommons.org/licenses/by/4.0/> ;
    dct:source <https://www.boe.es/buscar/act.php?id=BOE-A-2004-4163> ;
    skos:note "Classes strictly aligned with the Spanish Real Decreto Legislativo 1/2004, de 5 de marzo, Ley del Catastro Inmobiliario."@en ;
    skos:note "Clases estrictamente alineadas con el Real Decreto Legislativo 1/2004, de 5 de marzo, Ley del Catastro Inmobiliario."@es .

# =============================================================================
# CONCEPT SCHEME
# =============================================================================

edintkos:Clase a skos:ConceptScheme ;
    dct:issued "2026-04-13"^^xsd:date ;
    dct:modified "2026-04-13"^^xsd:date ;
    cc:license <https://creativecommons.org/licenses/by/4.0/> ;
    rdfs:comment "This concept scheme belongs to the set of controlled SKOS-based thesauri used by the ontologies from the EDINT data space."@en ;
    rdfs:comment "Este esquema de conceptos pertenece al conjunto de tesauros SKOS usados por las ontologías del espacio de datos EDINT."@es ;
    rdfs:label "Classification"@en ;
    rdfs:label "Clasificación"@es ;
    dct:title "Concept scheme grouping property classifications"@en ;
    dct:title "Esquema de conceptos agrupando clasificaciones de inmuebles"@es ;
    skos:note "Values based on Article 7 and Article 8 of the Spanish Cadastre Law (RDLeg 1/2004)."@en ;
    skos:note "Valores basados en los Artículos 7 y 8 de la Ley del Catastro Inmobiliario de España (RDLeg 1/2004)."@es ;
    dct:source <https://www.boe.es/buscar/act.php?id=BOE-A-2004-4163> ;
    skos:hasTopConcept edintkos-clase:Urban ;
    skos:hasTopConcept edintkos-clase:Rural ;
    skos:hasTopConcept edintkos-clase:BICES .

# =============================================================================
# PROPERTY CLASSIFICATION (TOP CONCEPTS)
# =============================================================================

edintkos-clase:Urban a skos:Concept ;
    skos:inScheme edintkos:Clase ;
    skos:prefLabel "Urban"@en ;
    skos:prefLabel "Urbano"@es ;
    skos:definition "Property classified as urban based on the nature of its soil, in accordance with applicable urban planning legislation."@en ;
    skos:definition "Inmueble clasificado como urbano en función de la naturaleza de su suelo, de acuerdo con la legislación urbanística aplicable."@es ;
    dct:source <https://www.boe.es/buscar/act.php?id=BOE-A-2004-4163#art7> ;
    skos:topConceptOf edintkos:Clase .

edintkos-clase:Rural a skos:Concept ;
    skos:inScheme edintkos:Clase ;
    skos:prefLabel "Rural"@en ;
    skos:prefLabel "Rústico"@es ;
    skos:definition "Property classified as rural based on the nature of its soil, explicitly excluding properties designated as urban or special."@en ;
    skos:definition "Inmueble clasificado como rústico en función de la naturaleza de su suelo, excluyendo expresamente aquellos designados como urbanos o de características especiales."@es ;
    dct:source <https://www.boe.es/buscar/act.php?id=BOE-A-2004-4163#art7> ;
    skos:topConceptOf edintkos:Clase .

edintkos-clase:BICES a skos:Concept ;
    skos:inScheme edintkos:Clase ;
    skos:prefLabel "Real Estate of Special Characteristics (BICES)"@en ;
    skos:prefLabel "Bienes Inmuebles de Características Especiales (BICES)"@es ;
    skos:definition "Complex real estate properties with special characteristics such as nuclear power plants, dams, airports, commercial ports, and toll highways."@en ;
    skos:definition "Inmuebles complejos de características especiales, como centrales nucleares, presas, aeropuertos, puertos comerciales y autopistas de peaje."@es ;
    dct:source <https://www.boe.es/buscar/act.php?id=BOE-A-2004-4163#art8> ;
    skos:altLabel "Special"@en ;
    skos:altLabel "Especial"@es ;
    skos:topConceptOf edintkos:Clase ;
    skos:narrower edintkos-clase:BICES-A ,
                  edintkos-clase:BICES-B ,
                  edintkos-clase:BICES-C ,
                  edintkos-clase:BICES-D .

# =============================================================================
# BICES NARROWER CONCEPTS (ARTICLE 8.2 GROUPS)
# =============================================================================

edintkos-clase:BICES-A a skos:Concept ;
    skos:inScheme edintkos:Clase ;
    skos:prefLabel "Energy and Refining Infrastructure"@en ;
    skos:prefLabel "Infraestructuras de energía y refino"@es ;
    skos:definition "Properties destined for the production of electrical energy and gas, oil refining, and nuclear power plants."@en ;
    skos:definition "Inmuebles destinados a la producción de energía eléctrica y gas y al refino de petróleo, y las centrales nucleares."@es ;
    skos:broader edintkos-clase:BICES ;
    dct:source <https://www.boe.es/buscar/act.php?id=BOE-A-2004-4163#art8> .

edintkos-clase:BICES-B a skos:Concept ;
    skos:inScheme edintkos:Clase ;
    skos:prefLabel "Dams and Reservoirs"@en ;
    skos:prefLabel "Presas y embalses"@es ;
    skos:definition "Dams, waterfalls, and reservoirs, including their bed or basin, except those destined exclusively for irrigation."@en ;
    skos:definition "Las presas, saltos de agua y embalses, incluido su lecho o vaso, excepto las destinadas exclusivamente al riego."@es ;
    skos:broader edintkos-clase:BICES ;
    dct:source <https://www.boe.es/buscar/act.php?id=BOE-A-2004-4163#art8> .

edintkos-clase:BICES-C a skos:Concept ;
    skos:inScheme edintkos:Clase ;
    skos:prefLabel "Toll Roads and Tunnels"@en ;
    skos:prefLabel "Autopistas, carreteras y túneles de peaje"@es ;
    skos:definition "Toll highways, toll roads, and toll tunnels."@en ;
    skos:definition "Las autopistas, carreteras y túneles de peaje."@es ;
    skos:broader edintkos-clase:BICES ;
    dct:source <https://www.boe.es/buscar/act.php?id=BOE-A-2004-4163#art8> .

edintkos-clase:BICES-D a skos:Concept ;
    skos:inScheme edintkos:Clase ;
    skos:prefLabel "Airports and Commercial Ports"@en ;
    skos:prefLabel "Aeropuertos y puertos comerciales"@es ;
    skos:definition "Airports and commercial ports."@en ;
    skos:definition "Los aeropuertos y puertos comerciales."@es ;
    skos:broader edintkos-clase:BICES ;
    dct:source <https://www.boe.es/buscar/act.php?id=BOE-A-2004-4163#art8> .