@prefix rdfs: <http://www.w3.org/2000/01/rdf-syntax-ns#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix cc: <http://creativecommons.org/ns#> .
@prefix edintkos: <http://vocab.linkeddata.es/datosabiertos/kos/edint/> .

@prefix edintkos-estado: <http://vocab.linkeddata.es/datosabiertos/kos/edint/estado/> .

# =============================================================================
# ONTOLOGY METADATA
# =============================================================================

<http://vocab.linkeddata.es/datosabiertos/kos/edint/estado> a owl:Ontology ;
    owl:versionIRI <http://vocab.linkeddata.es/datosabiertos/kos/edint/estado/0.1.1> ;
    owl:versionInfo "0.1.1" ;
    dct:title "Controlled Vocabulary of Construction Conservation States for Spanish Cadastre"@en ;
    dct:title "Vocabulario Controlado de Estados de Conservación de la Construcción para el Catastro Español"@es ;
    dct:description "SKOS concept scheme defining the legally mandated construction conservation states in the Spanish Cadastre system according to RD 1020/1993."@en ;
    dct:description "Esquema de conceptos SKOS que define los estados de conservación de la construcción obligatorios por ley en el sistema del Catastro Español según el RD 1020/1993."@es ;
    dct:issued "2026-04-13"^^xsd:date ;
    dct:modified "2026-04-13"^^xsd:date ;
    dct:creator "Daniel Doña"@es ,
                "Edna Ruckhaus" ,
                "Lucía Sánchez" ,
                "Maria del Socorro Bernardos" ,
                "Oscar Corcho" ;
    cc:license <https://creativecommons.org/licenses/by/4.0/> ;
    dct:source <https://www.boe.es/buscar/act.php?id=BOE-A-1993-19265> ;
    skos:note "Classes strictly aligned with the Spanish Real Decreto 1020/1993, Norma 14 (Estado de conservación)."@en ;
    skos:note "Clases estrictamente alineadas con el Real Decreto 1020/1993, Norma 14 (Estado de conservación)."@es .

# =============================================================================
# CONCEPT SCHEME
# =============================================================================

edintkos:Estado a skos:ConceptScheme ;
    dct:issued "2026-04-13"^^xsd:date ;
    dct:modified "2026-04-13"^^xsd:date ;
    cc:license <https://creativecommons.org/licenses/by/4.0/> ;
    rdfs:comment "This concept scheme belongs to the set of controlled SKOS-based thesauri used by the ontologies from the EDINT data space."@en ;
    rdfs:comment "Este esquema de conceptos pertenece al conjunto de tesauros SKOS usados por las ontologías del espacio de datos EDINT."@es ;
    rdfs:label "Conservation State"@en ;
    rdfs:label "Estado de Conservación"@es ;
    dct:title "Concept scheme grouping construction conservation states"@en ;
    dct:title "Esquema de conceptos agrupando estados de conservación de la construcción"@es ;
    skos:note "Values based on Norma 14 of the Spanish Technical Valuation Norms (RD 1020/1993)."@en ;
    skos:note "Valores basados en la Norma 14 de las Normas Técnicas de Valoración (RD 1020/1993)."@es ;
    dct:source <https://www.boe.es/buscar/act.php?id=BOE-A-1993-19265#Norma14> ;
    skos:hasTopConcept edintkos-estado:Normal ;
    skos:hasTopConcept edintkos-estado:Regular ;
    skos:hasTopConcept edintkos-estado:Deficiente ;
    skos:hasTopConcept edintkos-estado:Ruinoso .

# =============================================================================
# CONSTRUCTION CONDITIONS (NORMA 14)
# =============================================================================

edintkos-estado:Normal a skos:Concept ;
    skos:inScheme edintkos:Estado ;
    skos:prefLabel "Normal"@en ;
    skos:prefLabel "Normal"@es ;
    skos:definition "Constructions that, despite their age, whatever it may be, do not require major repairs."@en ;
    skos:definition "Construcciones que, a pesar de su edad, cualquiera que fuera ésta, no necesitan reparaciones importantes."@es ;
    skos:altLabel "Functional"@en ;
    skos:altLabel "Funcional"@es ;
    dct:source <https://www.boe.es/buscar/act.php?id=BOE-A-1993-19265#Norma14> ;
    skos:topConceptOf edintkos:Estado .

edintkos-estado:Regular a skos:Concept ;
    skos:inScheme edintkos:Estado ;
    skos:prefLabel "Fair"@en ;
    skos:prefLabel "Regular"@es ;
    skos:definition "Constructions that present permanent defects, without compromising normal conditions of habitability and stability."@en ;
    skos:definition "Construcciones que presentan defectos permanentes, sin que comprometan las normales condiciones de habitabilidad y estabilidad."@es ;
    dct:source <https://www.boe.es/buscar/act.php?id=BOE-A-1993-19265#Norma14> ;
    skos:topConceptOf edintkos:Estado .

edintkos-estado:Deficiente a skos:Concept ;
    skos:inScheme edintkos:Estado ;
    skos:prefLabel "Deficient"@en ;
    skos:prefLabel "Deficiente"@es ;
    skos:definition "Constructions that require relatively important repairs, compromising normal conditions of habitability and stability."@en ;
    skos:definition "Construcciones que precisan reparaciones de relativa importancia, comprometiendo las normales condiciones de habitabilidad y estabilidad."@es ;
    skos:altLabel "Deteriorated"@en ;
    skos:altLabel "Deteriorado"@es ;
    dct:source <https://www.boe.es/buscar/act.php?id=BOE-A-1993-19265#Norma14> ;
    skos:topConceptOf edintkos:Estado .

edintkos-estado:Ruinoso a skos:Concept ;
    skos:inScheme edintkos:Estado ;
    skos:prefLabel "Ruined"@en ;
    skos:prefLabel "Ruinoso"@es ;
    skos:definition "Constructions that are manifestly uninhabitable or legally declared in ruin."@en ;
    skos:definition "Construcciones manifiestamente inhabitables o declaradas legalmente en ruina."@es ;
    skos:altLabel "In Ruins"@en ;
    skos:altLabel "En Escombros"@es ;
    dct:source <https://www.boe.es/buscar/act.php?id=BOE-A-1993-19265#Norma14> ;
    skos:topConceptOf edintkos:Estado .