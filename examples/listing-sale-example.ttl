@prefix edintinm: <http://vocab.linkeddata.es/datosabiertos/def/oferta-inmobiliaria/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix geo: <http://www.opengis.net/ont/geosparql#> .
@prefix catastro: <https://edint.github.io/edint-ontologia-catastro/ontology/catastro#> .
@prefix edintkos-uso: <http://vocab.linkeddata.es/datosabiertos/kos/edint/uso/> .
@prefix edintkos-trans: <http://vocab.linkeddata.es/datosabiertos/kos/edint/transaction-type/> .
@prefix ex: <http://example.org/> .

# Sale Listing Example: Residential Dwelling
# Ejemplo de Anuncio de Venta: Vivienda Residencial

ex:Listing001 a edintinm:RealEstateListing ;
    dcterms:identifier "LIST-001" ;
    dcterms:title "Vivienda en venta en Madrid" ;
    dcterms:title "Dwelling for sale in Madrid"@en ;
    edintinm:propertyType edintkos-uso:vivienda ;
    edintinm:transactionType edintkos-trans:Venta ;
    edintinm:isActive true ;
    edintinm:refersToCadastralEntity ex:CadastralProperty001 .

ex:CadastralProperty001 a catastro:CadastralProperty ;
    catastro:referenceCatastral "9876543BC4567N0001WO" ;
    catastro:hasAddress ex:Address001 ;
    geo:hasGeometry ex:Geometry001 .

ex:Address001 a catastro:Address ;
    catastro:roadName "Calle Mayor" ;
    catastro:roadNumber "15" ;
    catastro:zipCode "28013" ;
    catastro:city "Madrid" ;
    catastro:province "Madrid" .

ex:Geometry001 a geo:Geometry ;
    geo:asWKT "POLYGON((-3.7078 40.4173, -3.7068 40.4173, -3.7068 40.4163, -3.7078 40.4163, -3.7078 40.4173))"^^geo:wktLiteral .
