:Parcela_8942103VK2793
    a catastro:CadastralParcel ;
    rdfs:label "Parcela 8942103VK2793"@es ;
    rdfs:label "Parcel 8942103VK2793"@en ;
    catastro:hasCadastralReference :RefCatastral_8942103VK2793_Parcela ;
    catastro:hasCadastralProperty :Inmueble_8942103VK2793S0001UO ;
    catastro:hasClass edintkos-clase:Urban ;
    dct:source <https://www.sedecatastro.gob.es> .

:RefCatastral_8942103VK2793_Parcela
    a catastro:CadastralReference ;
    catastro:parcelReference "8942103VK2793" .

# Geometry for the parcel
:Geometria_Parcela_8942103VK2793
    a geo:Geometry ;
    geo:asWKT "<http://www.opengis.net/def/crs/EPSG/0/25830> polygon((430000.00 4470000.00, 430000.00 4470400.00, 430400.00 4470400.00, 430400.00 4470000.00, 430000.00 4470000.00))"^^geo:wktLiteral ;
    geo:hasSerialization "GML geometry from INSPIRE Cadastral Parcels" ;
    # Area: 407.586 m²
    geo:hasArea [
        a geo:SpatialMeasure ;
        geo:measureAmount "407.586"^^xsd:double ;
        qudt:unit qudtunit:M2
    ] .


# --- Address using callejero ontology ---

# Create address entities according to callejero ontology
:Via_BADAJOZ
    a callejero:Via ;
    rdfs:label "Calle Badajoz"@es ;
    callejero:nombreVia "BADAJOZ" ;
    callejero:tipoVia "CL" .  # CL = Calle

:Portal_348B
    a callejero:Portal ;
    rdfs:label "Portal 348[B]"@es ;
    callejero:numero "348" ;
    callejero:codigoPostal "28223" ;
    callejero:municipio "POZUELO DE ALARCÓN" ;
    callejero:provincia "MADRID" ;
    callejero:via :Via_BADAJOZ .


