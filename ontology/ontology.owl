    <owl:Ontology rdf:about="http://vocab.linkeddata.es/datosabiertos/def/oferta-inmobiliaria/">
        <owl:versionIRI rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/oferta-inmobiliaria/0.1.0"/>
        <owl:imports rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/catastro/"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-04-14</dcterms:created>
        <dcterms:creator xml:lang="es">Daniel Doña</dcterms:creator>
        <dcterms:creator>Edna Ruckhaus</dcterms:creator>
        <dcterms:creator>Lucía Sánchez</dcterms:creator>
        <dcterms:creator>Maria del Socorro Bernardos</dcterms:creator>
        <dcterms:creator>Oscar Corcho</dcterms:creator>
        <dcterms:description xml:lang="en">Ontology for modeling real estate listings in the Spanish context, including property offers (sale, rent, transfer). Integrates with the Spanish Cadastre ontology.</dcterms:description>
        <dcterms:description xml:lang="es">Ontología para modelar ofertas inmobiliarias en el contexto español, incluyendo ofertas de inmuebles (venta, alquiler, traspaso). Se integra con la ontología del Catastro Español.</dcterms:description>
        <dcterms:hasFormat rdf:resource="http://vocab.linkeddata.es/datosabiertos/def/oferta-inmobiliaria.owl"/>
        <dcterms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-04-17</dcterms:issued>
        <dcterms:license rdf:resource="https://creativecommons.org/licenses/by/4.0/"/>
        <dcterms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-04-17</dcterms:modified>
        <dcterms:title xml:lang="es">Ontología de Oferta Inmobiliaria Española</dcterms:title>
        <dcterms:title xml:lang="en">Spanish Real Estate Listing Ontology</dcterms:title>
        <vann:preferredNamespacePrefix>edintinm</vann:preferredNamespacePrefix>
        <vann:preferredNamespaceUri rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">http://vocab.linkeddata.es/datosabiertos/def/oferta-inmobiliaria/</vann:preferredNamespaceUri>
        <owl:versionInfo>0.1.0</owl:versionInfo>
    </owl:Ontology>
    


