@prefix edintcat: <https://edint.github.io/edint-ontologia-inmuebles/ontology/catastro#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix vann: <http://purl.org/vocab/vann/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix geo: <http://www.opengis.net/ont/geosparql#> .
@prefix callejero: <http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/callejero#> .
@prefix qudt: <http://qudt.org/schema/qudt/> .
@prefix qudtunit: <http://qudt.org/vocab/unit/> .
@prefix cc: <http://creativecommons.org/ns#> .

# =============================================================================
# ONTOLOGY METADATA
# =============================================================================

<https://edint.github.io/edint-ontologia-inmuebles/ontology/catastro> a owl:Ontology ;
    owl:versionIRI <https://edint.github.io/edint-ontologia-inmuebles/ontology/catastro/0.1.0> ;
    owl:versionInfo "0.1.0" ;
    dcterms:title "Spanish Cadastre Ontology"@en ;
    dcterms:title "Ontología del Catastro Español"@es ;
    dcterms:description "Ontology for modeling Spanish Cadastre entities, focused on Parcels, Properties and Buildings. Reuses GeoSPARQL, INSPIRE concepts, and the Spanish street catalog (callejero) vocabulary."@en ;
    dcterms:description "Ontología para modelar las entidades del Catastro Español, centrada en Parcelas, Inmuebles y Construcciones. Reutiliza GeoSPARQL, conceptos INSPIRE y el vocabulario de callejero español."@es ;
    dcterms:created "2026-04-09"^^xsd:date ;
    dcterms:modified "2026-04-09"^^xsd:date ;
    dcterms:creator "Daniel Doña"@es ,
                    "Edna Ruckhaus" ,
                    "Lucía Sánchez" ,
                    "Maria del Socorro Bernardos" ,
                    "Oscar Corcho" ;
    cc:license <https://creativecommons.org/licenses/by/4.0/> ;
    dcterms:license <https://creativecommons.org/licenses/by/4.0/> ;
    owl:imports <http://www.opengis.net/ont/geosparql> ,
                <http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/callejero> ,
                <http://vocab.linkeddata.es/datosabiertos/kos/edint/uso> ,
                <http://vocab.linkeddata.es/datosabiertos/kos/edint/clase> ;
    rdfs:comment "Initial draft version focusing on core classes: CadastralParcel, CadastralProperty, and CadastralConstruction with their relationships and properties."@en ;
    rdfs:comment "Versión inicial centrada en las clases principales: ParcelaCatastral, Inmueble y Construcción con sus relaciones y propiedades."@es ;
    vann:preferredNamespaceUri "https://edint.github.io/edint-ontologia-inmuebles/ontology/catastro#" ;
    vann:preferredNamespacePrefix "edintcat" .

dcterms:contributor a owl:AnnotationProperty .
dcterms:created a owl:AnnotationProperty .
dcterms:creator a owl:AnnotationProperty .
dcterms:description a owl:AnnotationProperty .
dcterms:license a owl:AnnotationProperty .
dcterms:modified a owl:AnnotationProperty .
dcterms:source a owl:AnnotationProperty .
dcterms:title a owl:AnnotationProperty .
vann:preferredNamespacePrefix a owl:AnnotationProperty .
vann:preferredNamespaceUri a owl:AnnotationProperty .
owl:versionIRI a owl:AnnotationProperty .
owl:versionInfo a owl:AnnotationProperty .
cc:license a owl:AnnotationProperty .

# =============================================================================
# CLASSES
# =============================================================================

# --- Core Classes ---

edintcat:CadastralParcel
    a owl:Class ;
    rdfs:label "Cadastral Parcel"@en ;
    rdfs:label "Parcela Catastral"@es ;
    rdfs:comment "Basic unit of territorial division in the Spanish Cadastre. Represents a plot of land delimited geographically, which may contain one or more properties."@en ;
    rdfs:comment "Unidad básica de división territorial en el Catastro Español. Representa una porción de terreno delimitada geográficamente, que puede contener uno o más inmuebles."@es ;
    rdfs:subClassOf geo:Feature ;
    rdfs:subClassOf [
        a owl:Restriction ;
        owl:onProperty edintcat:hasCadastralReference ;
        owl:cardinality "1"^^xsd:nonNegativeInteger
    ] .

edintcat:CadastralProperty
    a owl:Class ;
    rdfs:label "Cadastral Property"@en ;
    rdfs:label "Inmueble Catastral"@es ;
    rdfs:comment "Real estate property registered in the Cadastre. Can be a premises, dwelling, or any independent use unit within a parcel. A cadastral property may have one or more constructions associated."@en ;
    rdfs:comment "Bien inmueble inscrito en el Catastro. Puede ser un local, vivienda, o cualquier unidad de uso independiente dentro de una parcela. Un inmueble catastral puede tener una o más construcciones asociadas."@es ;
    rdfs:subClassOf geo:Feature ;
    rdfs:subClassOf [
        a owl:Restriction ;
        owl:onProperty edintcat:hasCadastralReference ;
        owl:cardinality "1"^^xsd:nonNegativeInteger
    ] .

edintcat:CadastralReference
    a owl:Class ;
    rdfs:label "Cadastral Reference"@en ;
    rdfs:label "Referencia Catastral"@es ;
    rdfs:comment "Complete cadastral reference composed of parcel reference and property reference."@en ;
    rdfs:comment "Referencia catastral completa compuesta por referencia de parcela y referencia de inmueble."@es .

edintcat:CadastralConstruction
    a owl:Class ;
    rdfs:label "Cadastral Construction"@en ;
    rdfs:label "Construcción Catastral"@es ;
    rdfs:comment "Building or construction registered on a cadastral property. Includes data on area, use, construction characteristics, and renovations. A cadastral construction can be associated with one or more cadastral properties."@en ;
    rdfs:comment "Edificio o construcción registrada sobre un inmueble catastral. Incluye datos de superficie, uso, características constructivas y reformas. Una construcción catastral puede estar asociada a uno o más inmuebles catastrales."@es ;
    rdfs:subClassOf geo:Feature .

# --- Supporting Classes ---

edintcat:Renovation
    a owl:Class ;
    rdfs:label "Renovation"@en ;
    rdfs:label "Reforma"@es ;
    rdfs:comment "Event or process of renovating a construction, including information about when it occurred and what type of renovation was performed."@en ;
    rdfs:comment "Evento o proceso de reforma de una construcción, incluyendo información sobre cuándo ocurrió y qué tipo de reforma se realizó."@es .

# Use geo:Geometry directly from GeoSPARQL
# Geometry types (Polygon, MultiPolygon, etc.) are defined in GeoSPARQL
# Area measurements use geo:hasArea with geo:SpatialMeasure

# =============================================================================
# OBJECT PROPERTIES
# =============================================================================

# --- Geometry ---

# Use geo:hasGeometry from GeoSPARQL (standard property)
# Domain restriction for cadastral entities can be added via subPropertyOf or local constraints

# --- Cadastral hierarchy ---

edintcat:hasCadastralProperty
    a owl:ObjectProperty ;
    rdfs:label "has cadastral property"@en ;
    rdfs:label "tiene inmueble catastral"@es ;
    rdfs:domain edintcat:CadastralParcel ;
    rdfs:range edintcat:CadastralProperty ;
    rdfs:comment "Relationship indicating that a cadastral parcel contains one or more cadastral properties (e.g., flats in a horizontal division)."@en ;
    rdfs:comment "Relación que indica que una parcela catastral contiene uno o más inmuebles catastrales (ej. pisos en una división horizontal)."@es ;
    owl:inverseOf edintcat:onCadastralParcel .

edintcat:onCadastralParcel
    a owl:ObjectProperty ;
    rdfs:label "on cadastral parcel"@en ;
    rdfs:label "sobre parcela catastral"@es ;
    rdfs:comment "Relationship indicating that a cadastral property is located on a specific cadastral parcel."@en ;
    rdfs:comment "Relación que indica que un inmueble catastral está ubicado sobre una parcela catastral específica."@es ;
    rdfs:domain edintcat:CadastralProperty ;
    rdfs:range edintcat:CadastralParcel ;
    owl:inverseOf edintcat:hasCadastralProperty .

edintcat:hasCadastralConstruction
    a owl:ObjectProperty ;
    rdfs:label "has cadastral construction"@en ;
    rdfs:label "tiene construcción catastral"@es ;
    rdfs:domain edintcat:CadastralProperty ;
    rdfs:range edintcat:CadastralConstruction ;
    rdfs:comment "Relationship indicating the specific constructive units (locales/parts) that make up a cadastral property."@en ;
    rdfs:comment "Relación que indica las unidades constructivas específicas (locales/partes) que conforman un inmueble catastral."@es ;
    owl:inverseOf edintcat:onCadastralProperty .

edintcat:onCadastralProperty
    a owl:ObjectProperty ;
    rdfs:label "on cadastral property"@en ;
    rdfs:label "en inmueble catastral"@es ;
    rdfs:comment "Relationship indicating that a cadastral construction is located on a specific cadastral property."@en ;
    rdfs:comment "Relación que indica que una construcción catastral está ubicada sobre un inmueble catastral específico."@es ;
    rdfs:domain edintcat:CadastralConstruction ;
    rdfs:range edintcat:CadastralProperty ;
    owl:inverseOf edintcat:hasCadastralConstruction .

edintcat:hasHorizontalDivision
    a owl:DatatypeProperty ;
    rdfs:label "has horizontal division"@en ;
    rdfs:label "tiene división horizontal"@es ;
    rdfs:domain [
        a owl:Class ;
        owl:unionOf (edintcat:CadastralParcel edintcat:CadastralConstruction) ;
    ] ;
    rdfs:range xsd:boolean ;
    rdfs:comment "Boolean indicating whether a parcel or construction is subject to horizontal division regime."@en ;
    rdfs:comment "Booleano que indica si una parcela o construcción está sujeta a régimen de división horizontal."@es .


edintcat:hasAddress
    a owl:ObjectProperty ;
    rdfs:label "has address"@en ;
    rdfs:label "tiene dirección"@es ;
    rdfs:domain [
        a owl:Class ;
        owl:unionOf (edintcat:CadastralProperty edintcat:CadastralParcel) ;
    ] ;
    rdfs:range callejero:Portal ;
    rdfs:comment "Relationship linking a property or parcel to its address in the callejero vocabulary. Through this relationship, location information (municipality, province, postal code) can be obtained from the linked callejero:Portal."@en ;
    rdfs:comment "Relación que vincula un inmueble o parcela con su dirección en el vocabulario callejero. A través de esta relación, se puede obtener información de ubicación (municipio, provincia, código postal) del Portal enlazado."@es ;
    rdfs:isDefinedBy <http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/callejero> .


# --- Use relationship ---

edintcat:hasUse
    a owl:ObjectProperty ;
    rdfs:label "has use"@en ;
    rdfs:label "tiene uso"@es ;
    rdfs:domain [
        a owl:Class ;
        owl:unionOf (edintcat:CadastralProperty edintcat:CadastralConstruction) ;
    ] ;
    rdfs:range skos:Concept ;
    rdfs:comment "Relationship that assigns a primary use to a property or construction. Use concepts are defined in the external SKOS vocabulary at http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/uso."@en ;
    rdfs:comment "Relación que asigna un uso principal a un inmueble o construcción. Los conceptos de uso se definen en el vocabulario SKOS externo en http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/uso."@es .

edintcat:hasClass
    a owl:ObjectProperty ;
    rdfs:label "has class"@en ;
    rdfs:label "tiene clase"@es ;
    rdfs:domain [
        a owl:Class ;
        owl:unionOf (edintcat:CadastralParcel edintcat:CadastralProperty) ;
    ] ;
    rdfs:range skos:Concept ;
    rdfs:comment "Relationship that assigns a classification (urban/rural) to a parcel or property. Classification concepts are defined in external SKOS vocabulary at http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/clase."@en ;
    rdfs:comment "Relación que asigna una clasificación (urbano/rústico) a una parcela o inmueble. Los conceptos de clasificación se definen en el vocabulario SKOS externo en http://vocab.linkeddata.es/datosabiertos/def/urbanismo-infraestructuras/clase."@es .



# --- Temporal relationships ---

# (None - construction date is modeled as datatype property constructionYear)

# --- Renovation relationships ---


edintcat:hasRenovation
    a owl:ObjectProperty ;
    rdfs:label "has renovation"@en ;
    rdfs:label "tiene reforma"@es ;
    rdfs:domain edintcat:CadastralConstruction ;
    rdfs:range edintcat:Renovation ;
    rdfs:comment "Relationship indicating that a construction has undergone one or more renovation events."@en ;
    rdfs:comment "Relación que indica que una construcción ha sufrido una o más reformas."@es ;
    owl:inverseOf edintcat:renovationOf .

edintcat:renovationOf
    a owl:ObjectProperty ;
    rdfs:label "renovation of"@en ;
    rdfs:label "reforma de"@es ;
    rdfs:domain edintcat:Renovation ;
    rdfs:range edintcat:CadastralConstruction ;
    rdfs:comment "Relationship indicating that a renovation event applies to a specific construction."@en ;
    rdfs:comment "Relación que indica que un evento de reforma se aplica a una construcción específica."@es ;
    owl:inverseOf edintcat:hasRenovation .

# --- Reference ---

edintcat:hasCadastralReference
    a owl:ObjectProperty ;
    rdfs:label "has cadastral reference"@en ;
    rdfs:label "tiene referencia catastral"@es ;
    rdfs:domain [
        a owl:Class ;
        owl:unionOf (edintcat:CadastralParcel edintcat:CadastralProperty) ;
    ] ;
    rdfs:range edintcat:CadastralReference ;
    rdfs:comment "Relationship linking a cadastral entity to its complete cadastral reference."@en ;
    rdfs:comment "Relación que vincula una entidad catastral con su referencia catastral completa."@es .

# --- Real Estate Listings ---

edintcat:hasListing
    a owl:ObjectProperty ;
    rdfs:label "has real estate listing"@en ;
    rdfs:label "tiene anuncio inmobiliario"@es ;
    rdfs:domain [
        a owl:Class ;
        owl:unionOf (edintcat:CadastralParcel edintcat:CadastralProperty) ;
    ] ;
    rdfs:range <https://edint.github.io/edint-ontologia-inmuebles/ontology/inmobiliaria#RealEstateListing> ;
    rdfs:comment "Relationship indicating that a cadastral parcel or property has one or more real estate listings associated (offers, rentals, etc.)."@en ;
    rdfs:comment "Relación que indica que una parcela o inmueble catastral tiene uno o más anuncios inmobiliarios asociados (ofertas, alquileres, etc.)."@es ;
    owl:inverseOf <https://edint.github.io/edint-ontologia-inmuebles/ontology/inmobiliaria#refersToCadastralEntity> .

# =============================================================================
# DATA PROPERTIES
# =============================================================================

# --- Identifiers ---

edintcat:parcelReference
    a owl:DatatypeProperty ;
    rdfs:label "parcel reference"@en ;
    rdfs:label "referencia de parcela"@es ;
    rdfs:domain edintcat:CadastralReference ;
    rdfs:range xsd:string ;
    rdfs:comment "The 7-digit parcel reference part. Format: 7 digits (e.g., 0569302)."@en ;
    rdfs:comment "La parte de 7 dígitos de la referencia de parcela. Formato: 7 dígitos (ej. 0569302)."@es ;
    rdfs:isDefinedBy <https://www.sedecatro.gob.es> .

edintcat:propertyReference
    a owl:DatatypeProperty ;
    rdfs:label "property reference"@en ;
    rdfs:label "referencia de inmueble"@es ;
    rdfs:domain edintcat:CadastralReference ;
    rdfs:range xsd:string ;
    rdfs:comment "The property reference part including check digit. Format: alphanumeric with check (e.g., TF8006N0001HZ)."@en ;
    rdfs:comment "La parte de referencia de inmueble incluyendo dígito de control. Formato: alfanumérico con control (ej. TF8006N0001HZ)."@es ;
    rdfs:isDefinedBy <https://www.sedecatastro.gob.es> .

edintcat:participation
    a owl:DatatypeProperty ;
    rdfs:label "participation"@en ;
    rdfs:label "participación"@es ;
    rdfs:domain edintcat:CadastralProperty ;
    rdfs:range xsd:decimal ;
    qudt:applicableUnit qudtunit:PCT ;
    rdfs:comment "Percentage of participation in common elements of the parcel or construction."@en ;
    rdfs:comment "Porcentaje de participación en elementos comunes de la parcela o construcción."@es .

edintcat:supportPercentage
    a owl:DatatypeProperty ;
    rdfs:label "support percentage"@en ;
    rdfs:label "porcentaje de soporte"@es ;
    rdfs:domain edintcat:CadastralConstruction ;
    rdfs:range xsd:decimal ;
    qudt:applicableUnit qudtunit:PCT ;
    rdfs:comment "Percentage of the construction area that is considered support area (common elements)."@en ;
    rdfs:comment "Porcentaje del área de construcción que se considera área de soporte (elementos comunes)."@es .

edintcat:constructionYear
    a owl:DatatypeProperty ;
    rdfs:label "construction year"@en ;
    rdfs:label "año de construcción"@es ;
    rdfs:domain edintcat:CadastralConstruction ;
    rdfs:range xsd:gYear ;
    rdfs:comment "Year in which the building was constructed."@en ;
    rdfs:comment "Año en que se construyó el edificio."@es .

edintcat:staircase
    a owl:DatatypeProperty ;
    rdfs:label "staircase"@en ;
    rdfs:label "escalera"@es ;
    rdfs:domain edintcat:CadastralConstruction ;
    rdfs:range xsd:string ;
    rdfs:comment "Staircase identifier for a construction unit within a building."@en ;
    rdfs:comment "Identificador de escalera para una unidad de construcción dentro de un edificio."@es .

edintcat:floor
    a owl:DatatypeProperty ;
    rdfs:label "floor"@en ;
    rdfs:label "planta"@es ;
    rdfs:domain edintcat:CadastralConstruction ;
    rdfs:range xsd:string ;
    rdfs:comment "Floor level identifier for a construction unit (can include basement levels like -1, -2)."@en ;
    rdfs:comment "Identificador de planta para una unidad de construcción (puede incluir plantas sótano como -1, -2)."@es .

edintcat:door
    a owl:DatatypeProperty ;
    rdfs:label "door"@en ;
    rdfs:label "puerta"@es ;
    rdfs:domain edintcat:CadastralConstruction ;
    rdfs:range xsd:string ;
    rdfs:comment "Door or unit identifier within a floor and staircase."@en ;
    rdfs:comment "Identificador de puerta o unidad dentro de una planta y escalera."@es .

edintcat:renovationType
    a owl:DatatypeProperty ;
    rdfs:label "renovation type"@en ;
    rdfs:label "tipo de reforma"@es ;
    rdfs:domain edintcat:Renovation ;
    rdfs:range xsd:string ;
    rdfs:comment "Type of renovation performed."@en ;
    rdfs:comment "Tipo de reforma realizada."@es .

edintcat:renovationDate
    a owl:DatatypeProperty ;
    rdfs:label "renovation date"@en ;
    rdfs:label "fecha de reforma"@es ;
    rdfs:domain edintcat:Renovation ;
    rdfs:range xsd:date ;
    rdfs:comment "Date when the renovation was performed."@en ;
    rdfs:comment "Fecha en que se realizó la reforma."@es .

# =============================================================================
# END OF ONTOLOGY
# =============================================================================
